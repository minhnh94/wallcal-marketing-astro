---
interface Props {
  title: string;
  image: string;
  imageAlt: string;
  features: string[];
}

const { title, image, imageAlt, features } = Astro.props;
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20">
      <div class="lg:flex lg:flex-row-reverse lg:items-center lg:gap-16">
        <!-- Image (right) -->
        <div class="lg:w-1/2 mb-8 lg:mb-0" data-aos="fade-up">
          <img src={image} alt={imageAlt} class="w-full rounded-2xl shadow-xl" loading="lazy" />
        </div>
        <!-- Content (left) -->
        <div class="lg:w-1/2" data-aos="fade-up" data-aos-delay="150">
          <h3 class="text-3xl md:text-4xl font-bold mb-4">{title}</h3>
          <ul class="space-y-3">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="fill-blue-500 shrink-0 mt-1" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
                  <circle cx="8" cy="8" r="8" opacity="0.15" />
                  <path d="M7.105 11.354l-3.25-3.25a.75.75 0 0 1 1.06-1.06l2.72 2.72 4.47-4.47a.75.75 0 0 1 1.06 1.06l-5 5a.75.75 0 0 1-1.06 0z" />
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
