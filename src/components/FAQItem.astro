---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div
  x-data="{ expanded: false }"
  class="relative isolate bg-white/70 shadow-lg shadow-black/[0.03] rounded-lg
         before:absolute before:inset-0 before:-z-[1] before:rounded-[inherit] before:border
         before:border-transparent before:[background:linear-gradient(var(--color-gray-100),var(--color-gray-200))_border-box]
         before:[mask:linear-gradient(white_0_0)_padding-box,_linear-gradient(white_0_0)]
         before:[mask-composite:exclude_!important] before:pointer-events-none"
>
  <h2>
    <button
      class="flex items-center justify-between w-full font-semibold text-left px-4 py-3"
      data-posthog-event="faq_item_toggled"
      data-posthog-question={question}
      @click="expanded = !expanded"
      :aria-expanded="expanded"
    >
      <span>{question}</span>
      <span class="flex items-center justify-center h-5 w-5 rounded-full bg-white shadow-xs shrink-0 ml-8">
        <svg
          class="fill-gray-400 transform origin-center transition duration-200 ease-out"
          :class="{'rotate-180!': expanded}"
          xmlns="http://www.w3.org/2000/svg"
          width="10"
          height="6"
          fill="none"
        >
          <path
            d="m2 .586 3 3 3-3L9.414 2 5.707 5.707a1 1 0 0 1-1.414 0L.586 2 2 .586Z"
            clip-rule="evenodd"
          />
        </svg>
      </span>
    </button>
  </h2>
  <div
    class="grid text-sm text-gray-600 overflow-hidden transition-all duration-300 ease-in-out"
    :class="expanded ? 'grid-rows-[1fr] opacity-100' : 'grid-rows-[0fr] opacity-0'"
  >
    <div class="overflow-hidden">
      <p class="px-4 pb-3">{answer}</p>
    </div>
  </div>
</div>
