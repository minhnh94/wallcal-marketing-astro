---
import type { FAQItem } from '../lib/notion';
import FAQItemComponent from './FAQItem.astro';

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20">
      <div class="max-w-3xl mx-auto text-center pb-12 md:pb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold">Frequently Asked Questions</h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4" data-aos="fade-up">
        {items.map((item) => (
          <FAQItemComponent question={item.question} answer={item.answer} />
        ))}
      </div>
    </div>
  </div>
</section>
