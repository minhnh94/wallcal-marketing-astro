---
// FeatureGrid: 3-column grid of secondary features with Cruip theme styling
// Content mirrors the existing WallCal site's OtherFeatureList section
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20">

      <!-- Section heading -->
      <div class="max-w-3xl mx-auto text-center pb-12 md:pb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold">More features to explore</h2>
      </div>

      <!-- Feature grid -->
      <div class="grid lg:grid-cols-3 overflow-hidden border-y [border-image:linear-gradient(to_right,transparent,var(--color-slate-200),transparent)1] *:p-6 md:*:px-10 md:*:py-12 *:relative *:before:absolute *:before:bg-linear-to-b *:before:from-transparent *:before:via-gray-200 *:before:[block-size:100%] *:before:[inline-size:1px] *:before:[inset-inline-start:-1px] *:before:[inset-block-start:0]">

        <!-- 1. Resize & positioning -->
        <article data-aos="fade-up">
          <h3 class="font-medium flex items-center space-x-2 mb-2">
            <svg class="fill-blue-500" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
              <path d="M1 1h5v2H3.414l3.293 3.293-1.414 1.414L2 4.414V7H0V1a1 1 0 0 1 1-1zm14 0a1 1 0 0 1 1 1v6h-2V4.414l-3.293 3.293-1.414-1.414L12.586 3H10V1h5zM2 11.586l3.293-3.293 1.414 1.414L3.414 13H6v2H1a1 1 0 0 1-1-1v-6h2v2.586zm12 0V9h2v6a1 1 0 0 1-1 1h-5v-2h2.586l-3.293-3.293 1.414-1.414L14 11.586z" />
            </svg>
            <span>Resize &amp; positioning</span>
          </h3>
          <p class="text-[15px] text-gray-700">Put WallCal anywhere on your desktop and resize it to fit your workflow perfectly.</p>
        </article>

        <!-- 2. Multiple calendars -->
        <article data-aos="fade-up" data-aos-delay="100">
          <h3 class="font-medium flex items-center space-x-2 mb-2">
            <svg class="fill-blue-500" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
              <path d="M3 0a1 1 0 0 0-1 1v1H1a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-1h1a1 1 0 0 0 1-1V3h1a1 1 0 0 0 1-1V1a1 1 0 0 0-1-1H3zm7 12H2V5h8v7zm2-2V4a1 1 0 0 0-1-1H4V2h10v8h-2z" />
            </svg>
            <span>Multiple calendars</span>
          </h3>
          <p class="text-[15px] text-gray-700">Display events from all your calendars — iCloud, Google, Exchange, and more — in one view.</p>
        </article>

        <!-- 3. Multi-screen support -->
        <article data-aos="fade-up" data-aos-delay="200">
          <h3 class="font-medium flex items-center space-x-2 mb-2">
            <svg class="fill-blue-500" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
              <path d="M1 2a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2zm1 0v4h5V2H2zM9 9a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V9zm1 0v5h4V9h-4zM1 10a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1v-4zm1 0v4h4v-4H2zM10 1a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-3a1 1 0 0 1-1-1V1zm1 0v4h3V1h-3z" />
            </svg>
            <span>Multi-screen support</span>
          </h3>
          <p class="text-[15px] text-gray-700">Show WallCal on any connected display, or have different layouts on each screen.</p>
        </article>

        <!-- 4. Customizable appearance -->
        <article data-aos="fade-up">
          <h3 class="font-medium flex items-center space-x-2 mb-2">
            <svg class="fill-blue-500" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
              <path d="M11.334 1.126a2 2 0 0 1 2.243.676l1.252 1.67a2 2 0 0 1-.282 2.707l-8.2 7.38a2 2 0 0 1-.865.458l-3.46.865a.5.5 0 0 1-.61-.61l.866-3.46a2 2 0 0 1 .457-.865l7.38-8.2a2 2 0 0 1 1.22-.62zM12.6 2.52a.5.5 0 0 0-.866.002L4.35 10.728a.5.5 0 0 0-.114.216l-.6 2.397 2.396-.6a.5.5 0 0 0 .217-.114l8.198-7.38a.5.5 0 0 0 .07-.676L13.266 2.9a.5.5 0 0 0-.56-.17l-.106.04v-.25z" />
            </svg>
            <span>Customizable appearance</span>
          </h3>
          <p class="text-[15px] text-gray-700">Choose fonts, colors, opacity, and layout to match your wallpaper and style.</p>
        </article>

        <!-- 5. Menu bar quick access -->
        <article data-aos="fade-up" data-aos-delay="100">
          <h3 class="font-medium flex items-center space-x-2 mb-2">
            <svg class="fill-blue-500" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
              <path d="M0 1a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V1zm2 .5a.5.5 0 1 0 1 0 .5.5 0 0 0-1 0zm2 0a.5.5 0 1 0 1 0 .5.5 0 0 0-1 0zM1 6h14v9a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6zm4 2a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1H5z" />
            </svg>
            <span>Menu bar quick access</span>
          </h3>
          <p class="text-[15px] text-gray-700">Glance at your schedule from the menu bar without switching away from your current app.</p>
        </article>

        <!-- 6. Keyboard shortcuts -->
        <article data-aos="fade-up" data-aos-delay="200">
          <h3 class="font-medium flex items-center space-x-2 mb-2">
            <svg class="fill-blue-500" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
              <path d="M0 3a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3zm2 0v10h12V3H2zm2 2h2v2H4V5zm3 0h2v2H7V5zm3 0h2v2h-2V5zM4 8h8v2H4V8zm2 3h4v1H6v-1z" />
            </svg>
            <span>Keyboard shortcuts</span>
          </h3>
          <p class="text-[15px] text-gray-700">Navigate months, toggle views, and control WallCal entirely from your keyboard.</p>
        </article>

      </div>
    </div>
  </div>
</section>
