---
// Hero section: headline, description, and 3 download CTAs (App Store, Setapp, FDM)
---

<div class="max-w-6xl mx-auto px-4 sm:px-6">
  <div class="pt-32 pb-12 md:pt-40 md:pb-20">
    <!-- Hero content -->
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-6" data-aos="zoom-y-out">
        Your calendar,<br />right on your desktop
      </h1>
      <p class="text-xl text-gray-600 mb-10" data-aos="zoom-y-out" data-aos-delay="150">
        WallCal puts a beautiful, fully customizable calendar on your Mac wallpaper — so you never miss what's next.
      </p>

      <!-- Download CTAs -->
      <div class="relative before:absolute before:inset-0 before:border-y before:[border-image:linear-gradient(to_right,transparent,--theme(--color-slate-300/.8),transparent)1]" data-aos="zoom-y-out" data-aos-delay="300">
        <div class="relative max-w-xs mx-auto sm:max-w-none py-4 flex flex-col sm:flex-row sm:justify-center sm:gap-4 items-center">

          <!-- App Store -->
          <a
            class="btn text-white bg-linear-to-t from-blue-600 to-blue-500 bg-[length:100%_100%] hover:bg-[length:100%_150%] bg-[bottom] shadow-sm w-full mb-3 sm:w-auto sm:mb-0 group plausible-event-name=CTA+AppStore"
            href="https://apps.apple.com/app/wallcal-wallpaper-calendar/id1581367286"
            target="_blank"
            rel="nofollow noreferrer"
          >
            <span class="relative inline-flex items-center">
              App Store <span class="tracking-normal text-blue-300 group-hover:translate-x-0.5 transition-transform ml-1">&rarr;</span>
            </span>
          </a>

          <!-- Setapp -->
          <a
            class="btn text-white bg-linear-to-t from-blue-600 to-blue-500 bg-[length:100%_100%] hover:bg-[length:100%_150%] bg-[bottom] shadow-sm w-full mb-3 sm:w-auto sm:mb-0 group plausible-event-name=CTA+Setapp"
            href="https://go.setapp.com/stp355?refAppID=541"
            target="_blank"
            rel="nofollow noreferrer"
          >
            <span class="relative inline-flex items-center">
              Setapp <span class="tracking-normal text-blue-300 group-hover:translate-x-0.5 transition-transform ml-1">&rarr;</span>
            </span>
          </a>

          <!-- FDM -->
          <a
            class="btn text-white bg-linear-to-t from-blue-600 to-blue-500 bg-[length:100%_100%] hover:bg-[length:100%_150%] bg-[bottom] shadow-sm w-full mb-3 sm:w-auto sm:mb-0 group plausible-event-name=CTA+FDM"
            href="https://en.freedownloadmanager.org/Mac-OS/WallCal-FREE.html"
            target="_blank"
            rel="nofollow noreferrer"
          >
            <span class="relative inline-flex items-center">
              Free Download <span class="tracking-normal text-blue-300 group-hover:translate-x-0.5 transition-transform ml-1">&rarr;</span>
            </span>
          </a>

        </div>
      </div>
    </div>
  </div>
</div>
