---
import Logo from './Logo.astro';
---

<footer>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 py-8 md:py-12 border-t border-gray-200">

      <!-- Logo -->
      <Logo />

      <!-- Contact -->
      <p class="text-sm text-gray-600">
        Contact us at <a class="text-gray-900 hover:underline transition" href="mailto:tsukie.studio@gmail.com" data-posthog-event="support_email_clicked" data-posthog-location="footer" data-posthog-email="support@wallcal.app">support@wallcal.app</a>
      </p>

      <!-- Social + Copyright -->
      <div class="flex items-center gap-4">
        <!-- Twitter/X icon -->
        <a class="flex justify-center items-center text-blue-500 hover:text-blue-600 transition" href="https://twitter.com/WallCalApp" target="_blank" rel="nofollow noreferrer" aria-label="Twitter" data-posthog-event="social_link_clicked" data-posthog-location="footer" data-posthog-network="twitter">
          <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <path d="m13.063 9 3.495 4.475L20.601 9h2.454l-5.359 5.931L24 23h-4.938l-3.866-4.893L10.771 23H8.316l5.735-6.342L8 9h5.063Zm-.74 1.347h-1.457l8.875 11.232h1.36l-8.778-11.232Z"></path>
          </svg>
        </a>
        <span class="text-sm text-gray-600">&copy; tsukie</span>
      </div>

    </div>
  </div>

  <!-- Big text glow effect -->
  <div class="relative -mt-16 h-60 w-full -z-10" aria-hidden="true">
    <div class="absolute left-1/2 pointer-events-none -z-10 -translate-x-1/2 text-[348px] leading-none text-center font-bold before:content-['WallCal'] before:bg-linear-to-b before:from-gray-200 before:to-gray-100/30 before:to-80% before:text-transparent before:bg-clip-text after:content-['WallCal'] after:absolute after:inset-0 after:bg-gray-300/70 after:text-transparent after:bg-clip-text after:[text-shadow:0_1px_0_white] after:mix-blend-darken"></div>
    <!-- Glow -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-2/3" aria-hidden="true">
      <div class="w-56 h-56 rounded-full border-[20px] border-blue-700 blur-[80px] will-change-[filter]"></div>
    </div>
  </div>
</footer>
