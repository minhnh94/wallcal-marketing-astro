---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact Us - WallCal">
  <section class="relative pt-32 pb-12 md:pt-40 md:pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-8" data-aos="zoom-y-out">Contact Us</h1>
      <p class="text-lg text-gray-600 mb-10" data-aos="zoom-y-out" data-aos-delay="150">
        If you purchased our macOS app WallCal/WallCal Lite and you encountered any troubles, or need support regarding a specific function, please don't hesitate to email us.
      </p>
      <div class="space-y-6" data-aos="zoom-y-out" data-aos-delay="300">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-2">Support</h2>
          <a class="text-lg text-blue-600 hover:text-blue-700 transition" href="mailto:support@wallcal.app">support@wallcal.app</a>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 mb-2">Inquiries</h2>
          <a class="text-lg text-blue-600 hover:text-blue-700 transition" href="mailto:contact@wallcal.app">contact@wallcal.app</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
